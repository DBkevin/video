TRTC_RECORDING_SECRET_ID=
TRTC_RECORDING_SECRET_KEY=
# 腾讯云TRTC录制回调里配置的自定义key，用于校验 Sign=Base64(HMAC-SHA256(rawBody, key))
TRTC_RECORDING_CALLBACK_KEY=
TRTC_RECORDING_REGION=ap-shanghai
TRTC_RECORDING_RESOURCE_EXPIRED_HOUR=72
TRTC_RECORDING_MAX_IDLE_TIME=30
TRTC_RECORDING_MIX_WIDTH=720
TRTC_RECORDING_MIX_HEIGHT=1280
TRTC_RECORDING_MIX_FPS=15
TRTC_RECORDING_MIX_BITRATE=1200
TRTC_RECORDING_MIX_LAYOUT_MODE=3
TRTC_RECORDING_VOD_SUB_APP_ID=0
TRTC_RECORDING_VOD_EXPIRE_TIME=0
# 需要在腾讯云TRTC录制回调配置中指向本服务的POST /api/v1/trtc/recording/callback
