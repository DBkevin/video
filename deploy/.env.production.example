SERVER_ADDR=127.0.0.1:8080
GIN_MODE=release

# Ubuntu 24 服务器数据库在 120.25.70.117，正式部署时请替换成真实账号密码
MYSQL_DSN=root:replace-with-mysql-password@tcp(127.0.0.1:3306)/video_consult_mvp?charset=utf8mb4&parseTime=True&loc=Asia%2FShanghai
# 正式环境建议先执行 docs/schema.sql，再关闭自动迁移，避免 GORM 在已有索引/外键上做危险变更
MYSQL_AUTO_MIGRATE=false

# Redis 如与服务部署在同一台服务器，也可改成 127.0.0.1:6379
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

JWT_SECRET=replace-with-strong-production-secret
JWT_ISSUER=video-consult-mvp
JWT_EXPIRE_HOURS=72

TRTC_SDK_APP_ID=1400000000
TRTC_SECRET_KEY=replace-with-server-secret
TRTC_USER_SIG_EXPIRE=86400

TRTC_RECORDING_ENABLED=true
TRTC_RECORDING_SECRET_ID=replace-with-tencentcloud-secret-id
TRTC_RECORDING_SECRET_KEY=replace-with-tencentcloud-secret-key
TRTC_RECORDING_CALLBACK_KEY=replace-with-trtc-callback-key
TRTC_RECORDING_REGION=ap-shanghai
TRTC_RECORDING_RESOURCE_EXPIRED_HOUR=72
TRTC_RECORDING_MAX_IDLE_TIME=30
TRTC_RECORDING_MIX_WIDTH=720
TRTC_RECORDING_MIX_HEIGHT=1280
TRTC_RECORDING_MIX_FPS=15
TRTC_RECORDING_MIX_BITRATE=1200
TRTC_RECORDING_MIX_LAYOUT_MODE=3
TRTC_RECORDING_VOD_SUB_APP_ID=0
TRTC_RECORDING_VOD_EXPIRE_TIME=0
TRTC_RECORDING_CALLBACK_URL=https://hxtest.xmmylike.com/api/v1/trtc/recording/callback

CONSULT_SESSION_EXPIRE_MINUTES=120
CONSULT_ENTRY_PAGE_PATH=/pages/customer-entry/index

WECHAT_MINIAPP_APP_ID=replace-with-wechat-miniapp-appid
WECHAT_MINIAPP_APP_SECRET=replace-with-wechat-miniapp-secret
WECHAT_MINIAPP_MOCK_LOGIN_SALT=video-consult-mvp
