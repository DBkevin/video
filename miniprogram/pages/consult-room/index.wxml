<view class="page">
  <view class="card">
    <view class="pill">{{role === 'doctor' ? '医生通话页' : '顾客候诊页'}}</view>
    <view class="title">{{role === 'doctor' ? '正在发起视频面诊' : '已进入候诊，等待医生接入'}}</view>
    <view class="subtitle">页面会直接接入官方 TUICallKit。医生端进入后会发起视频呼叫，顾客端进入后会保持在线等待接听。</view>

    <view wx:if="{{loading}}" class="section">
      <view class="value">{{statusText}}</view>
    </view>

    <view wx:if="{{errorMessage}}" class="error">{{errorMessage}}</view>

    <block wx:if="{{session}}">
      <view class="section">
        <view class="label">会话编号</view>
        <view class="value">{{session.session_no}}</view>
      </view>

      <view class="section">
        <view class="label">房间号</view>
        <view class="value">{{session.room_id}}</view>
      </view>

      <view class="section">
        <view class="label">SDK 提供方</view>
        <view class="value">{{sdkProvider || '初始化中'}}</view>
      </view>

      <view class="section">
        <view class="label">当前角色</view>
        <view class="value">{{role === 'doctor' ? '医生' : '顾客'}}</view>
      </view>

      <view class="section">
        <view class="label">会话状态</view>
        <view class="value">{{session.status}}</view>
      </view>

      <view class="section">
        <view class="label">{{peerTitle}}</view>
        <view class="value">{{peerName}}</view>
      </view>

      <view class="section" wx:if="{{statusText}}">
        <view class="label">通话提示</view>
        <view class="value">{{statusText}}</view>
      </view>
    </block>

    <button wx:if="{{role === 'doctor'}}" class="button warn" loading="{{finishLoading}}" bindtap="handleFinishConsult">结束面诊</button>
    <button wx:if="{{role === 'doctor'}}" class="button secondary" bindtap="handleBackToDoctorDetail">返回会话详情</button>
    <button wx:if="{{role !== 'doctor'}}" class="button secondary" loading="{{leaving}}" bindtap="handleLeavePage">离开当前页面</button>
  </view>
  <debug-panel page-name="consult-room"></debug-panel>
</view>
