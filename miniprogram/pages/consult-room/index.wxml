<view class="page">
  <view class="card">
    <view class="pill">{{role === 'doctor' ? '医生通话页' : '顾客候诊页'}}</view>
    <view class="title">{{role === 'doctor' ? '正在发起视频面诊' : '已进入候诊，等待医生接入'}}</view>
    <view class="subtitle">页面会优先尝试初始化 TUICallKit；如果本地还未安装官方 SDK，则会自动切到 mock 模式方便先联调接口。</view>

    <view wx:if="{{loading}}" class="section">
      <view class="value">正在初始化通话环境...</view>
    </view>

    <view wx:if="{{errorMessage}}" class="error">{{errorMessage}}</view>

    <block wx:if="{{session}}">
      <view class="section">
        <view class="label">会话编号</view>
        <view class="value">{{session.session_no}}</view>
      </view>

      <view class="section">
        <view class="label">房间号</view>
        <view class="value">{{session.room_id}}</view>
      </view>

      <view class="section">
        <view class="label">SDK 提供方</view>
        <view class="value">{{sdkProvider || '初始化中'}}</view>
      </view>

      <view class="section" wx:if="{{doctor}}">
        <view class="label">医生信息</view>
        <view class="value">{{doctor.name}} · {{doctor.title}}</view>
      </view>

      <view class="section" wx:if="{{customer}}">
        <view class="label">顾客信息</view>
        <view class="value">{{customer.nickname || customer.mobile}}</view>
      </view>
    </block>

    <button wx:if="{{role === 'doctor'}}" class="button warn" loading="{{finishLoading}}" bindtap="handleFinishConsult">结束面诊</button>
    <button wx:if="{{role !== 'doctor'}}" class="button secondary" bindtap="handleLeavePage">离开当前页面</button>
  </view>
</view>
