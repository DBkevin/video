<view class="page">
  <view class="card">
    <view class="pill">回放页</view>
    <view class="title">面诊录制回放</view>
    <view class="subtitle">医生可在此快速确认录制文件是否已生成并播放。</view>

    <view wx:if="{{errorMessage}}" class="error">{{errorMessage}}</view>

    <block wx:else>
      <view class="section" wx:if="{{sessionNo}}">
        <view class="label">会话编号</view>
        <view class="value">{{sessionNo}}</view>
      </view>

      <view class="section">
        <view class="label">回放地址</view>
        <view class="value">{{videoUrl}}</view>
      </view>

      <video
        class="player"
        src="{{videoUrl}}"
        controls
        autoplay
        objectFit="contain"
        show-center-play-btn
        show-fullscreen-btn
      />

      <button class="button secondary" bindtap="handleCopyPlaybackURL">复制回放链接</button>
      <view class="hint">如果当前设备未能直接播放，请先复制回放链接到浏览器或播放器中查看。</view>
    </block>
  </view>
</view>
