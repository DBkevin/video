<view class="page">
  <view class="card">
    <view class="pill">医生端</view>
    <view class="title">面诊会话详情</view>
    <view class="subtitle">这里既可作为创建成功页，也可用于轮询顾客是否已加入并发起视频面诊。</view>

    <view wx:if="{{loading}}" class="hint">正在刷新会话状态...</view>
    <view wx:if="{{errorMessage}}" class="error">{{errorMessage}}</view>

    <block wx:if="{{session}}">
      <view class="section" wx:if="{{doctor}}">
        <view class="label">当前医生</view>
        <view class="value">{{doctor.name}} · {{doctor.title}}</view>
      </view>

      <view class="section">
        <view class="label">会话编号</view>
        <view class="value">{{session.session_no}}</view>
      </view>

      <view class="section">
        <view class="label">当前状态</view>
        <view class="value">{{session.status}}</view>
      </view>

      <view class="section">
        <view class="label">录制状态</view>
        <view class="value">
          <text wx:if="{{recordingTask}}" class="{{recordingTask.status_class}}">{{recordingTask.status_label}}</text>
          <text wx:else class="status-tag idle">未开始</text>
        </view>
        <view wx:if="{{recordingTask}}" class="hint recording-hint">{{recordingTask.status_hint}}</view>
      </view>

      <view class="section" wx:if="{{recordingTask && recordingTask.task_id}}">
        <view class="label">录制任务ID</view>
        <view class="value">{{recordingTask.task_id}}</view>
      </view>

      <view class="section" wx:if="{{recordingTask && recordingTask.file_id}}">
        <view class="label">录制文件ID</view>
        <view class="value">{{recordingTask.file_id}}</view>
      </view>

      <view class="section">
        <view class="label">分享路径</view>
        <view class="value">{{sharePath || '尚未生成分享入口'}}</view>
      </view>

      <view class="section">
        <view class="label">顾客状态</view>
        <view class="value">{{customer ? customer.nickname || customer.mobile : '顾客尚未加入'}}</view>
      </view>

      <view class="section">
        <view class="label">当前提示</view>
        <view class="value">
          {{session.status === 'created' ? '请先生成分享入口' :
            session.status === 'shared' ? '已分享，等待顾客加入' :
            session.status === 'joined' ? '顾客已就绪，可以开始视频面诊' :
            session.status === 'in_consult' ? '正在面诊中，可进入通话页继续处理' :
            session.status === 'cancelled' ? '会话已取消' :
            session.status === 'expired' ? '会话已过期，请重新创建' :
            '会话已结束'}}
        </view>
      </view>
    </block>

    <button class="button secondary" loading="{{busyAction}}" bindtap="handleGenerateShare">生成分享入口</button>
    <button class="button secondary" bindtap="handleCopySharePath">复制分享路径</button>
    <button class="button secondary" wx:if="{{recordingTask && recordingTask.video_url}}" bindtap="handleOpenPlayback">查看回放</button>
    <button class="button secondary" wx:if="{{recordingTask && recordingTask.video_url}}" bindtap="handleCopyPlaybackURL">复制回放链接</button>
    <button class="button" disabled="{{!canStart || busyAction}}" loading="{{busyAction}}" bindtap="handleStartConsult">进入视频面诊</button>
    <button class="button warn" disabled="{{busyAction || !session || session.status === 'finished' || session.status === 'cancelled' || session.status === 'expired'}}" loading="{{busyAction}}" bindtap="handleCancelSession">取消当前会话</button>

    <view class="hint">
      {{recordingTask && (recordingTask.status === 'recording' || recordingTask.status === 'stopping')
        ? '页面会持续轮询录制状态，直到回放地址准备完成。'
        : '页面会每 3 秒轮询一次会话状态，顾客加入后即可开始面诊。'}}
    </view>
  </view>
</view>
