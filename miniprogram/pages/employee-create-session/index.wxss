.page-shell {
  min-height: 100vh;
  padding: 24rpx;
  background: linear-gradient(180deg, #f8fbff 0%, #eef4ff 100%);
}

.card {
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  display: grid;
  gap: 18rpx;
  box-shadow: 0 18rpx 48rpx rgba(15, 23, 42, 0.08);
}

.badge,
.picker,
.input,
.textarea,
.primary-btn,
.secondary-btn {
  border-radius: 20rpx;
}

.badge {
  width: fit-content;
  padding: 8rpx 20rpx;
  background: #e8f1ff;
  color: #3557a8;
  font-size: 24rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #0f172a;
}

.subtitle,
.hint,
.label,
.value {
  font-size: 28rpx;
  color: #475569;
}

.error {
  color: #c2410c;
  font-size: 28rpx;
}

.field {
  display: grid;
  gap: 10rpx;
}

.picker,
.input,
.textarea {
  width: 100%;
  background: #f8fafc;
  padding: 20rpx 24rpx;
}

.textarea {
  min-height: 160rpx;
}

.primary-btn {
  background: linear-gradient(135deg, #0f766e 0%, #14b8a6 100%);
  color: #fff;
}

.actions {
  display: grid;
  gap: 16rpx;
}

.secondary-btn {
  background: #dbe4f3;
  color: #0f172a;
}
