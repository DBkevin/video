.page-shell {
  min-height: 100vh;
  padding: 24rpx;
  background: linear-gradient(180deg, #f8fbff 0%, #eef4ff 100%);
}

.hero-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 18rpx 48rpx rgba(18, 52, 86, 0.08);
  display: grid;
  gap: 20rpx;
}

.badge {
  display: inline-flex;
  align-items: center;
  width: fit-content;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: #e7f0ff;
  color: #3056a6;
  font-size: 24rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #0f172a;
}

.subtitle,
.info-item,
.loading,
.label {
  color: #475569;
  font-size: 28rpx;
}

.error {
  color: #c2410c;
  font-size: 28rpx;
}

.form-item {
  display: grid;
  gap: 10rpx;
}

.input {
  width: 100%;
  min-height: 88rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  background: #f8fafc;
}

.actions {
  display: grid;
  gap: 16rpx;
}

.primary-btn,
.secondary-btn {
  border-radius: 999rpx;
}

.primary-btn {
  background: linear-gradient(135deg, #0f766e 0%, #14b8a6 100%);
  color: #fff;
}

.secondary-btn {
  background: #dbe4f3;
  color: #0f172a;
}
