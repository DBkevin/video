.page-shell {
  min-height: 100vh;
  padding: 24rpx;
  background: linear-gradient(180deg, #f8fbff 0%, #eef4ff 100%);
}

.card {
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  display: grid;
  gap: 18rpx;
  box-shadow: 0 18rpx 48rpx rgba(15, 23, 42, 0.08);
}

.header-row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: center;
}

.badge {
  width: fit-content;
  padding: 8rpx 20rpx;
  background: #e8f1ff;
  color: #3557a8;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.title {
  margin-top: 12rpx;
  font-size: 44rpx;
  font-weight: 700;
  color: #0f172a;
}

.small-btn,
.picker,
.session-item {
  border-radius: 20rpx;
}

.small-btn {
  margin: 0;
  font-size: 26rpx;
  background: #dbe4f3;
  color: #0f172a;
}

.picker,
.session-item {
  background: #f8fafc;
  padding: 20rpx 24rpx;
}

.session-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
}

.session-meta,
.hint {
  font-size: 26rpx;
  color: #475569;
}

.error {
  font-size: 26rpx;
  color: #c2410c;
}
