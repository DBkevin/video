.page {
  min-height: 100vh;
  padding: 48rpx 32rpx;
  background: #f5f7fb;
  box-sizing: border-box;
}

.placeholder-card {
  padding: 32rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.08);
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.desc {
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #64748b;
}
